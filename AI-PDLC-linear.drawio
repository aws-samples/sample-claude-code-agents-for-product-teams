<mxfile host="Electron" agent="claude-code" version="29.3.0" pages="1">
  <diagram id="linear-flow" name="Linear-Flow">
    <mxGraphModel dx="2400" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2410" pageHeight="6044" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
                <mxCell id="title" value="AI-PDLC Linear Flow — Swim Lanes by Role × Phase" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="40" y="10" width="2330" height="40" as="geometry" /></mxCell>
        <mxCell id="ph-0" value="&lt;b&gt;1. Discover&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;frame opportunity, validate problem, exit with funded bet&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="210" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-1" value="&lt;b&gt;2. Define&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;approved requirements, scope, NFRs, KPIs, regulatory scope&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="450" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-2" value="&lt;b&gt;3. Design&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;build-ready design: UX + arch + data + APIs + threat model&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="690" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-3" value="&lt;b&gt;4. Plan&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;team, envs, pipeline, test strategy, SLOs, work-ready backlog&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="930" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-4" value="&lt;b&gt;5. Build&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;working, tested, instrumented increments meeting DoD&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="1170" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-5" value="&lt;b&gt;6. Verify&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;evidence-based readiness to launch in production-like conditions&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="1410" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-6" value="&lt;b&gt;7. Launch&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;product live, enabled, stabilized, baseline captured&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="1650" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-7" value="&lt;b&gt;8. Operate&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;stable SLO-meeting service + profitable, retained customers&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="1890" y="60" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="ph-8" value="&lt;b&gt;9. Iterate&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:10px'&gt;measure vs. business case; continue / pivot / sunset; feed Discover&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;spacing=4;" vertex="1" parent="1"><mxGeometry x="2130" y="60" width="240" height="56" as="geometry" /></mxCell>
